<Application x:Class="SFCH.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SFCH"                      xmlns:Fluent="urn:fluent-ribbon"  
xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="Login.xaml">
    <Application.Resources>
        


            <ResourceDictionary>


                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="pack://application:,,,/Fluent;component/Themes/Generic.xaml" />

                    <!-- change "Cobalt" to the color you want// StartupUri="Login.xaml" -->
                    <ResourceDictionary Source="pack://application:,,,/Fluent;component/Themes/Themes/Light.Cobalt.xaml" />
                    <!-- Attach default Theme -->
                    <ResourceDictionary Source="pack://application:,,,/Fluent;Component/Themes/Generic.xaml" />
                    <!-- Tema de Material Design -->
                    <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                    <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Indigo" SecondaryColor="Lime" >

                    </materialDesign:BundledTheme>


                    <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                </ResourceDictionary.MergedDictionaries>
                <!-- Definir colores personalizados en hexadecimal -->

            </ResourceDictionary>
        
    </Application.Resources>
</Application>
