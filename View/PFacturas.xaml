<Page x:Class="SFCH.View.PFacturas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SFCH.View" xmlns:dgx="clr-namespace:DataGridExtensions;assembly=DataGridExtensions"
      mc:Ignorable="d"  xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PFacturas">

    <Grid Margin="5" >
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" >
            <TextBlock  Text="Facturas" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,10"/>
            <ProgressBar Name="progreso" IsIndeterminate="True" Height="5" ></ProgressBar>
        </StackPanel>
        <DataGrid Grid.Row="1" dgx:DataGridFilter.IsAutoFilterEnabled="True" AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding faturas}" x:Name="data">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Name="mbtnvisualizar" Header="Imprimir Factura PV" Click="mbtnvisualizar_Click"></MenuItem>
                    <MenuItem Name="mbtnimprimirGrande" Header="Imprimir Factura Grande" Click="mbtnimprimirGrande_Click"></MenuItem>
                    <MenuItem Name="mbtnAnular" Header="Anular" Click="mbtnAnular_Click"></MenuItem>
                </ContextMenu>
          
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Numero" Binding="{Binding Id}" Width="auto"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaEmision,StringFormat='{}{0:dd/MM/yyy}'}" Width="auto"/>
                <!--<DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="auto"/>-->
                <DataGridTextColumn Header="Nombre Cliente" Binding="{Binding NombreCliente}" Width="*"/>
                <DataGridTextColumn Header="Plazo" Binding="{Binding DiasPlazo,StringFormat='{} {0:0} Dias'}" Width="auto"/>
                <DataGridTextColumn Header="Condición" Binding="{Binding Condicion}" Width="auto"/>
                <DataGridTextColumn Header="Total" Binding="{Binding Total,StringFormat=C}" Width="auto"/>
                <DataGridTextColumn Header="Pendiente" Binding="{Binding TotalPendiente,StringFormat=C}" Width="auto"/>
                <DataGridTextColumn Header="Efectivo" Binding="{Binding Efectivo,StringFormat=C}" Width="auto"/>
                <DataGridTextColumn Header="Tarjeta" Binding="{Binding Tarjeta,StringFormat=C}" Width="auto"/>
 
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
