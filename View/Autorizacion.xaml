<Window x:Class="SFCH.View.Autorizacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SFCH.View"
        mc:Ignorable="d"
        Title="Autorizacion" Height="350" Width="466">
    <Grid>
        <StackPanel>
            <TextBlock FontSize="20" Margin="10" HorizontalAlignment="Center">Autorización de Anulación</TextBlock>
            <TextBox x:Name="txtconcepto" Margin="10" Height="70" Style="{StaticResource MaterialDesignOutlinedTextBox}"></TextBox>
            <TextBox x:Name="txtclave" Margin="10" Style="{StaticResource MaterialDesignOutlinedTextBox}"></TextBox>
            <Button Margin="10" Height="50" Click="Button_Click">Autorizar</Button>
        </StackPanel>
    </Grid>
</Window>
