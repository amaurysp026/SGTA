<Window x:Class="SFCH.View.VAbrirTurno"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SFCH.View"
        mc:Ignorable="d" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Abrir Nuevo Turno" Height="280" Width="400" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" >
    <Grid>
        <Grid.ColumnDefinitions>

            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.ColumnSpan="2" Text="Abrir Turno" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,10"/>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,0,0,0">
            <TextBox x:Name="txtMontoInicial" KeyDown="txtMontoInicial_KeyDown" Margin="5" materialDesign:HintAssist.Hint="Efectivo Inicial En Caja" Style="{StaticResource MaterialDesignOutlinedTextBox}"   FontSize="16" VerticalContentAlignment="Center" />
            <PasswordBox x:Name="txtClave" KeyDown="txtClave_KeyDown" Margin="5" materialDesign:HintAssist.Hint="Clave de Usuario" Style="{StaticResource MaterialDesignOutlinedPasswordBox}"   FontSize="16" VerticalContentAlignment="Center" />
        </StackPanel>
        <Button Grid.Row="2"  Content="Abrir Turno" Width="150" Height="40" FontSize="16" HorizontalAlignment="Center" Click="BtnAbrirTurno_Click"/>
        <Button Grid.Row="2" Grid.Column="1"  Content="Cancelar" Background="OrangeRed" Width="150" Height="40" FontSize="16" HorizontalAlignment="Center" Click="Button_Click"/>
        
    </Grid>
</Window>
