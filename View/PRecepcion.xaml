<Page x:Class="SFCH.View.PRecepcion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SFCH.View" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"    xmlns:mpvk="http://schemas.mpcoding.com/mpcoding/wpf/virtualkeys" xmlns:dgx="clr-namespace:DataGridExtensions;assembly=DataGridExtensions"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PRecepcion">

    <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition  Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition  Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock FontWeight="Bold" Text="RECEPCION DE LECHE" TextAlignment="Center"  ></TextBlock>

        <StackPanel Grid.Column="1" Background="LightBlue"  Visibility="Collapsed" >
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <StackPanel Margin="0 0 15 0" >

                    <StackPanel x:Name="stacpromedio" Visibility="Collapsed" Orientation="Horizontal">
                        <TextBlock FontSize="10" Margin="0 0" Text="Promedio: " FontWeight="Bold"></TextBlock>
                        <TextBlock FontSize="10" Name="txtpromedio"  Margin="0 0 5 0" Text="150" FontWeight="Bold" ></TextBlock>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock FontSize="14" Margin="0 0" Text="Usuario: " FontWeight="Bold"></TextBlock>
                        <TextBlock FontSize="12" Name="txtusuario"  Margin="0 0 5 0" Text="150" FontWeight="ExtraBold" ></TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel>
                    <TextBlock HorizontalAlignment="Right" Margin="0,0" Text="Hora Actual"></TextBlock>
                    <TextBlock HorizontalAlignment="Right" Margin="5,0" x:Name="txthora"  FontWeight="Bold" FontSize="15" ></TextBlock>
                </StackPanel>
                <Button x:Name="btnconfig" Padding="0" Margin="0,0" >
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"  Text=""></TextBlock>
                        <!--<fa:FontAwesome FontSize="10" Icon="Dashboard" Height="9" />-->
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.ColumnSpan="3">
                <TextBlock Grid.Row="0" Margin="10,0,0,0" Text="Nombre:"></TextBlock>
                <TextBlock x:Name="txtnombre" FontWeight="Bold" FontSize="20" Margin="10,0,0,0"></TextBlock>
            </StackPanel>
            <TextBox Margin="5"  mpvk:VirtualKeyPad.KeyPadWidth="300"
    mpvk:VirtualKeyPad.Mode="TouchAndMouse"  materialDesign:HintAssist.Hint="Codigo" LostFocus="txtcodigo_LostFocus" KeyDown="txtcodigo_KeyDown" Grid.Row="1" FontWeight="ExtraBlack" HorizontalContentAlignment="Center" VerticalAlignment="Top" FontSize="20" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="txtcodigo"></TextBox>
            <TextBox Grid.Row="1"  mpvk:VirtualKeyPad.KeyPadWidth="300"
    mpvk:VirtualKeyPad.Mode="TouchAndMouse" materialDesign:HintAssist.Hint="Litros" LostFocus="txtlitros_LostFocus" KeyDown="txtlitros_KeyDown" Margin="5" HorizontalContentAlignment="Center" FontWeight="ExtraBlack" Grid.Column="1" FontSize="20"  Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="txtlitros" ></TextBox>
            <Button Name="btnguardar" Grid.Row="1" Grid.Column="3" Height="50" Margin="5" Click="Button_Click" >
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FloppyDisk" Width="30" Height="30"></materialDesign:PackIcon>
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" >Registrar</TextBlock>
                    </StackPanel>
                </Button.Content>
               
            </Button>
            <Button  Grid.Row="2" Grid.Column="3" Height="50" Margin="5" >
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountCowboyHat" Width="30" Height="30"></materialDesign:PackIcon>
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
                    </StackPanel>
                </Button.Content>

            </Button>
            <Button Grid.Row="0" Grid.Column="3" Height="50" Margin="5"  >
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="KeyboardF9" Width="30" Height="30"></materialDesign:PackIcon>
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" >Buscar</TextBlock>
                    </StackPanel>
                </Button.Content>

            </Button>

            <ComboBox Grid.Row="2" HorizontalContentAlignment="Center" materialDesign:HintAssist.Hint="Frezzer No." FontSize="20" Name="cbf" SelectedIndex="-1" Style="{StaticResource MaterialDesignFilledComboBox}" Margin="5">
                <ComboBox.ItemTemplate>
                    <DataTemplate >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Path=Descripcion}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBox Grid.Row="2" Grid.Column="1" HorizontalContentAlignment="Center" Text="{Binding Tanda}" materialDesign:HintAssist.Hint="TANDA " IsReadOnly="True" FontSize="20" Name="cbT"  Style="{StaticResource MaterialDesignFilledTextBox}" Margin="5"/>


            <GroupBox Grid.Row="4" Grid.ColumnSpan="3" Header="DATOS RECEPCION ACTUAL" Background="LightBlue" Margin="5">
                <StackPanel Margin="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>


                        <StackPanel Grid.Row="1">

                            <TextBlock Margin="2,0"  FontWeight="Bold" Text="Num. Documento:"></TextBlock>
                            <TextBlock x:Name="txtrdocumento" Margin="2.0"  FontWeight="ExtraBold" Text="{Binding Id}"></TextBlock>
                            <Separator/>

                            <TextBlock Margin="2,0"  FontWeight="Bold" Text="Fecha:"></TextBlock>
                            <TextBlock x:Name="txtrfechacr" Margin="2,0,0,2" FontWeight="ExtraBold" Text="{Binding Fecha,StringFormat='{}dd/MM/yyy'}"></TextBlock>
                            <StackPanel>
                                <Separator/>
                                <TextBlock FontSize="12" Margin="0 0" Text="Total Registros: " FontWeight="Bold"></TextBlock>
                                <TextBlock FontSize="16" Name="txttRegistro"  Margin="0 0 5 0" Text="150" FontWeight="ExtraBold" ></TextBlock>
                            </StackPanel>
                            <StackPanel>
                                <Separator/>
                                <TextBlock FontSize="12" Margin="0 0"  Text="Total Litros: " FontWeight="Bold"></TextBlock>
                                <TextBlock FontSize="16" Name="txttlitros" Margin="0 0 5 0"  FontWeight="ExtraBold" />
                            </StackPanel>


                        </StackPanel>
                        

                            <DataGrid Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" x:Name="datalitros" IsReadOnly="True" AutoGenerateColumns="False">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem>
                                            <MenuItem.Header>
                                                <TextBlock>Reporte Unico</TextBlock>
                                            </MenuItem.Header>
                                            <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="TextBox"></materialDesign:PackIcon>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="auto" Header="Freezer" Binding="{Binding Path=Freezer.Descripcion}" />
                                    <DataGridTextColumn Width="*"  FontWeight="Bold" Header="Litros" Binding="{Binding Path=TotalLitros,StringFormat='{}{0:N2}'}" />
                                </DataGrid.Columns>
                            </DataGrid>


                        

                    </Grid>

                </StackPanel>
            </GroupBox>

            <Button Height="50" Margin="5" Grid.Row="5" Click="Button_Click_1">
                <TextBlock TextWrapping="WrapWithOverflow" TextAlignment="Center" >
                    Buscar Recepción
                </TextBlock>
            </Button>
            <Button Height="50" Margin="5" Grid.Row="5" Grid.Column="1" x:Name="btnNewRecepcion" Click="btnNewRecepcion_Click" >
                <TextBlock TextWrapping="WrapWithOverflow" TextAlignment="Center" >
                 Crear Nueva Recepción
                </TextBlock>
            </Button>
            <Button Height="50" Margin="5" Grid.Row="5" Grid.Column="2" >
              
                    <TextBlock TextWrapping="WrapWithOverflow" VerticalAlignment="Center" TextAlignment="Center" HorizontalAlignment="Center"  Text="Reporte Cuadre "></TextBlock>
                    <!--<fa:FontAwesome FontSize="19" Icon="Indent" />-->
   
            </Button>

        </Grid>


        <DataGrid Margin="5,0,0,10" IsReadOnly="True" AutoGenerateColumns="False" dgx:DataGridFilter.IsAutoFilterEnabled="True" Grid.Row="1" x:Name="data" AlternatingRowBackground="LightBlue" AlternationCount="2"   >


            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem >
                        <MenuItem.Header>
                            <TextBlock>Re-Imprimir</TextBlock>
                        </MenuItem.Header>
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="Printer"/>
                        </MenuItem.Icon>

                    </MenuItem>
                    <MenuItem Name="mbtnEditar" Click="mbtnEditar_Click" >
                        <MenuItem.Header>
                            <TextBlock>Editar</TextBlock>
                        </MenuItem.Header>
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="Edit"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Name="mbtnAnular"  Click="mbtnAnular_Click" >
                        <MenuItem.Header>
                            <TextBlock>Anular</TextBlock>
                        </MenuItem.Header>
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="Null"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <DataGridTextColumn Header="CODIGO" Binding="{Binding Path=Proveedor.Codigo, Mode=OneWay}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="NOMBRE ASOCIADO" Binding="{Binding Path=Proveedor.NombreCompleto}"></DataGridTextColumn>
                <DataGridTextColumn Header="LITROS" FontWeight="Bold" Binding="{Binding Path=Litros}"></DataGridTextColumn>
                <DataGridTextColumn Header="# VOLANTE" Binding="{Binding Path=Id}"></DataGridTextColumn>
                <DataGridTextColumn Header="HORA" Binding="{Binding Path=FechaEmision,StringFormat='{} hh:mm:ss tt'}"></DataGridTextColumn>
                <DataGridTextColumn Header="Frezzer" Binding="{Binding Path=Freezer.Descripcion}"></DataGridTextColumn>
                <!--<DataGridTextColumn Header="Tanda" Binding="{Binding Path=Tanda}"></DataGridTextColumn>-->
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Page>
