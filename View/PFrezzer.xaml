<Window x:Class="SFCH.View.PFrezzer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SFCH.View"
        mc:Ignorable="d"
        Title="Administrar Freezer" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Administrar Freezer" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Grid.ColumnSpan="2"/>
        <StackPanel Grid.Row="1" Grid.Column="1">
            <Button Height="50" Margin="5" Click="Button_Click" >
                <StackPanel>
                    <TextBlock>Agregar Nuevo</TextBlock>
                  
                </StackPanel>
            </Button>
            <Button Height="50" Margin="5" Name="btneditar" Click="btneditar_Click" >
                <StackPanel>
                    <TextBlock>Editar</TextBlock>

                </StackPanel>
            </Button>
            <Button Height="50" Margin="5" Name="btndesactivar" Click="btndesactivar_Click" >
                <StackPanel>
                    <TextBlock>Desactivar</TextBlock>

                </StackPanel>
            </Button>
            <Button Height="50" Margin="5" Name="btninforme" Click="btninforme_Click" >
                <StackPanel>
                    <TextBlock>Informe</TextBlock>

                </StackPanel>
            </Button>
        </StackPanel>
        <DataGrid x:Name="data" Margin="5" Grid.Row="1" Grid.ColumnSpan="1" CanUserAddRows="False" AutoGenerateColumns="False" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Numero" Binding="{Binding Numero}"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}"/>
                <DataGridTextColumn Header="Capacidad" Binding="{Binding CapacidadTotal,StringFormat=N2}">
                   
                </DataGridTextColumn>
                <DataGridTextColumn Header="Litros Actuales" Binding="{Binding TotalActual,StringFormat=N2}">

                </DataGridTextColumn>
                <DataGridTextColumn Header="Total Lt Registrados" Binding="{Binding TotalRegistrdo,StringFormat=N2}">

                </DataGridTextColumn>
                
                
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
