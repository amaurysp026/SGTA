<Window x:Class="SFCH.View.VBuscarAsog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dgx="clr-namespace:DataGridExtensions;assembly=DataGridExtensions"
        xmlns:local="clr-namespace:SFCH.View"
        mc:Ignorable="d"
        Title="Buscar Miembro en ASOGAFAR" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <DataGrid MouseDoubleClick="data_MouseDoubleClick" IsReadOnly="True" AutoGenerateColumns="False" x:Name="data" dgx:DataGridFilter.IsAutoFilterEnabled="True" SelectionChanged="data_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="AUTO"></DataGridTextColumn>
                <DataGridTextColumn Header="CODIGO" Binding="{Binding CODIGO}" Width="AUTO"></DataGridTextColumn>
                <DataGridTextColumn Header="NOMBRE COMPLETO" Binding="{Binding NOMBRE}" Width="AUTO"></DataGridTextColumn>
                <DataGridTextColumn Header="CEDULA" Binding="{Binding RNC}" Width="AUTO"></DataGridTextColumn>
                <DataGridTextColumn Header="CUENTA" Binding="{Binding CTABANC}" Width="AUTO"></DataGridTextColumn>
                <DataGridTextColumn Header="GENERO" Binding="{Binding GENERO}" Width="AUTO"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
