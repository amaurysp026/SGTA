<Page x:Class="SFCH.View.PUsuario"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SFCH.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PUsuario">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ComboBox x:Name="cbUsuarios" ItemsSource="{Binding usuarios}" Width="200" Height="30" Margin="10"/>
        <DataGrid x:Name="data"  RowEditEnding="Data_RowEditEnding" ItemsSource="{Binding usuarios}" Grid.Row="1" Margin="10">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Guardar Cambios" Click="MenuItem_Click"/>
                    <MenuItem Header="Desactivar Usuario" Click="MenuItem_Click_1" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Page>
