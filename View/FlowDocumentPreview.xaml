<Window x:Class="SFCH.View.FlowDocumentPreview"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SFCH.View"
        mc:Ignorable="d"
       Title="Previsualización FlowDocument" Height="450" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Botones de control -->
        <StackPanel Orientation="Horizontal" Margin="10" Grid.Row="0">
            <Button x:Name="btnCargar" Content="Cargar Documento" 
                    Click="btnCargar_Click" Margin="5" Padding="10,5"/>
            <Button x:Name="btnImprimir" Content="Vista Previa Impresión" 
                    Click="btnImprimir_Click" Margin="5" Padding="10,5"/>
        </StackPanel>

        <!-- FlowDocumentScrollViewer para previsualización -->
        <FlowDocumentScrollViewer x:Name="flowDocumentViewer" 
                                  Grid.Row="1" 
                                  Margin="10"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Zoom="100"/>
    </Grid>
</Window>
