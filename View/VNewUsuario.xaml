<Window x:Class="SFCH.View.VNewUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SFCH.View"  xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="VNewUsuario" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="1" FontSize="30" Grid.ColumnSpan="3" HorizontalAlignment="Center">Nuevo usuario</TextBlock>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" materialDesign:HintAssist.Hint="Nombre de Usuario" Name="txtNombreUsuario" Style="{StaticResource MaterialDesignOutlinedTextBox}"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="5" materialDesign:HintAssist.Hint="Nombre Completo" Name="txtNombreCompleto" Style="{StaticResource MaterialDesignOutlinedTextBox}"></TextBox>
        <TextBox Grid.Row="1" Grid.Column="2" Margin="5" materialDesign:HintAssist.Hint="Telefono" Name="txtTelefono" Style="{StaticResource MaterialDesignOutlinedTextBox}" ></TextBox>
        <PasswordBox x:Name="txtclave" Grid.Row="1" Grid.Column="3" materialDesign:HintAssist.Hint="Clave" Margin="5" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" ></PasswordBox>
        <TextBox Grid.Row="2" Grid.Column="2" materialDesign:HintAssist.Hint="Dirección" Grid.ColumnSpan="2" Margin="5" Style="{StaticResource MaterialDesignOutlinedTextBox}" Name="txtDireccion"></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" materialDesign:HintAssist.Hint="Cedula"  Margin="5" Style="{StaticResource MaterialDesignOutlinedTextBox}" Name="txtCedula"></TextBox>
        <Button Grid.Column="1" Grid.Row="4" Height="50" Click="Button_Click">Guardar</Button>
        <Button Grid.Column="3" Grid.Row="4" Height="50" Background="OrangeRed" Click="Button_Click_1" >Cancelar</Button>
    </Grid>
</Window>
