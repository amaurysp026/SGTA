<Window x:Class="SFCH.View.VNewEntidad"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SFCH.View"
        mc:Ignorable="d"  xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Nueva Entidad" Height="300" Width="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="auto" ></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Name="txtTitulo" Grid.Column="0" Grid.ColumnSpan="3" TextAlignment="Center" FontWeight="Bold" FontSize="30" HorizontalAlignment="Stretch"  >Nueva Entidad</TextBlock>
        <TextBox Grid.Row="1" Margin="6" CharacterCasing="Upper" Text="{Binding Nombre}" materialDesign:HintAssist.Hint="Nombre de Entidad" Grid.ColumnSpan="2" Style="{StaticResource  MaterialDesignOutlinedTextBox}"></TextBox>
        <TextBox Grid.Row="2" Margin="6" CharacterCasing="Upper" Text="{Binding Descripcion}" materialDesign:HintAssist.Hint="Descripción" Grid.ColumnSpan="2" Style="{StaticResource  MaterialDesignOutlinedTextBox}"></TextBox>
        <Button Click="Button_Click_1" Grid.Row="6" Height="50" Margin="5">
            Guardar
        </Button>
        <Button Background="red" Click="Button_Click" Grid.Row="6" Grid.Column="2" Height="50" Margin="5">
            Cancelar
        </Button>
    </Grid>
</Window>
