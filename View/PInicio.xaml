<Page x:Class="SFCH.View.PInicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SFCH.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PInicio">

    <Grid Margin="0,33,0,-33">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Image Name="img" Stretch="Uniform"></Image>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" >
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" x:Name="txtNombreEmpresa" FontSize="45" Foreground="Gray" VerticalAlignment="Center"  HorizontalAlignment="Center">Bienvenidos a SFCH System</TextBlock>
            <Separator Width="400" />
            <TextBlock FontWeight="Bold" FontSize="25" Name="txtSaludoUsuario" Foreground="Gray" VerticalAlignment="Top"  HorizontalAlignment="Center" >Hola!, Usuario</TextBlock>
            <TextBlock FontSize="15" Name="FechaInicio" Foreground="Red" VerticalAlignment="Top"  HorizontalAlignment="Center" >20/05/2025</TextBlock>
        </StackPanel>

    </Grid>
</Page>
