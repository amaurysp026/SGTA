<Page x:Class="SGTA.View.PRecepVehiculo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SGTA.View" xmlns:dgx="clr-namespace:DataGridExtensions;assembly=DataGridExtensions"
      mc:Ignorable="d"  xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PRecepVehiculo">

    <Grid Margin="5" Background="White" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
   

        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Título -->
        <TextBlock Text="Recepción de Vehículos" HorizontalAlignment="Center" Margin="3" FontSize="20" FontWeight="Bold" />

        <!-- Sección de Búsqueda -->
        <GroupBox Margin="5" Grid.Row="1" Visibility="Collapsed" Header="Búsqueda de Vehículo">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="5" materialDesign:HintAssist.Hint="Buscar Placa" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtPlaca"/>
                    <Button Grid.Column="1" Content="Buscar" Height="50" Margin="5"  Click="Button_Click"/>
                    <Button Grid.Column="2" Content="Registrar Cliente" Height="50" Margin="5"  Click="Button_Click"/>
                    <Button Grid.Column="3" Content="Clientes" Height="50" Margin="5"  Click="Button_Click"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Sección de Datos del Vehículo -->
        <GroupBox Grid.Row="2" Header="Datos del Vehículo" Margin="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Fila 1 -->

                <TextBox Grid.Column="0" Grid.Row="0" Text="{Binding vh.Marca}" CharacterCasing="Upper" Margin="5" materialDesign:HintAssist.Hint="Marca" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtModelo"/>
                <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding vh.Modelo}" CharacterCasing="Upper" Margin="5" materialDesign:HintAssist.Hint="Modelo"  Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtMarca"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding vh.Placa}" LostFocus="TxtPlacaVehiculo_LostFocus"  CharacterCasing="Upper" Margin="5" materialDesign:HintAssist.Hint="Placa Vehículo" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtPlacaVehiculo"  />

                <TextBox Grid.Column="0" Margin="5" Grid.Row="1" Text="{Binding vh.Año}"  materialDesign:HintAssist.Hint="Año" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtAño"/>
                <TextBox Grid.Column="0" Name="txtprop" Text="{Binding vh.Persona.Nombre}" Grid.Row="2" Margin="5" materialDesign:HintAssist.Hint="Propietario" Style="{StaticResource MaterialDesignOutlinedTextBox}" >
                
                </TextBox>
                <StackPanel Margin="0" Grid.Column="2" Grid.Row="2" Orientation="Horizontal" >
                    <Button  Margin="5" Height="50" Content="Agregar Propietario" x:Name="btnbuscarpro" Click="btnbuscarpro_Click"></Button>
                    <Button  Margin="5" Height="50" Content="Nuevo Cliente" Click="btnbuscarpro_Click"></Button>
                </StackPanel>
                <!-- Fila 4 -->

                <TextBox Margin="5" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2"  materialDesign:HintAssist.Hint="Observaciones" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtObservaciones" Padding="8" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                <StackPanel  Grid.Row="5"  Orientation="Horizontal" HorizontalAlignment="Center" >
                    <Button Content="Registrar" Click="Button_Click_1" Width="100" Height="50" Margin="5" Background="#4CAF50" Foreground="White"/>
                    <Button Content="Limpiar" Name="btnlimpiar" Click="btnlimpiar_Click" Width="100" Height="50"  Margin="5" Background="#2196F3" Foreground="White"/>
                    <Button Content="Cancelar" Name="btnCancelar" Click="btnCancelar_Click" Width="100" Height="50" Margin="5" Background="#f44336" Foreground="White"/>
                </StackPanel>
            </Grid>
        </GroupBox>
       
        <GroupBox Grid.Column="1" Grid.Row="2" Margin="5" Header="Vehiculos en Taller"  >
            <ListView x:Name="data">
             <ListView.ContextMenu>
     <ContextMenu>
         <MenuItem Header="Despachar Vehiculo" Click="MenuItem_Click">
             <MenuItem.Icon>
                 <materialDesign:PackIcon Kind="CarBack"  Foreground="Red"/>
             </MenuItem.Icon>
         </MenuItem>

     </ContextMenu>
 </ListView.ContextMenu>
                <ListView.View>
                    
                    <GridView>
                        <GridViewColumn Header="Nombre" DisplayMemberBinding="{Binding Persona.Nombre}" Width="auto"/>
                        <GridViewColumn Header="Placa" DisplayMemberBinding="{Binding Placa}" Width="100"/>
                        <GridViewColumn Header="Marca" DisplayMemberBinding="{Binding Marca}" Width="150"/>
                        <GridViewColumn Header="Modelo" DisplayMemberBinding="{Binding Modelo}" Width="150"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
        <!-- Sección de Botones -->
      

    </Grid>
</Page>
