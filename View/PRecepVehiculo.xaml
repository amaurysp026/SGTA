<Page x:Class="SGTA.View.PRecepVehiculo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SGTA.View" xmlns:dgx="clr-namespace:DataGridExtensions;assembly=DataGridExtensions"
      mc:Ignorable="d"  xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PRecepVehiculo">

    <Grid Background="White" >
        <StackPanel Margin="20">
            <!-- Título -->
            <TextBlock Text="Recepción de Vehículos" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Sección de Búsqueda -->
            <GroupBox Header="Búsqueda de Vehículo" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TxtPlaca" Padding="8" Height="35"/>
                        <Button Grid.Column="1" Content="Buscar" Margin="10,0,0,0" Padding="10" Click="Button_Click"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Sección de Datos del Vehículo -->
            <GroupBox Header="Datos del Vehículo" Margin="0,0,0,15" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Fila 1 -->

                    <TextBox materialDesign:HintAssist.Hint="Placa Vehículo" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtPlacaVehiculo" Padding="8" Height="30" IsReadOnly="True"/>

                    <TextBlock Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" Text="Marca:" FontWeight="Bold"/>
                    <TextBox Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" x:Name="TxtMarca" Padding="8" Height="30"/>
                        <TextBlock Text="Modelo:" FontWeight="Bold" />
                        <TextBox materialDesign:HintAssist.Hint="Modelo Vehiculo" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtModelo" Padding="8" Height="30"/>

                    <TextBox Grid.Column="1" Grid.Row="1"  materialDesign:HintAssist.Hint="Año" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtAño" Padding="8" Height="30"/>
                    <TextBox  Grid.Column="1" Grid.Row="2" materialDesign:HintAssist.Hint="Placa Vehículo" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtVIN" Padding="8" Height="30"/>
                    <!-- Fila 4 -->
                    <StackPanel Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <TextBlock Text="Observaciones:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox materialDesign:HintAssist.Hint="Placa Vehículo" Style="{StaticResource MaterialDesignOutlinedTextBox}" x:Name="TxtObservaciones" Padding="8" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Sección de Botones -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Guardar" Width="100" Padding="10" Margin="0,0,10,0" Background="#4CAF50" Foreground="White"/>
                <Button Content="Limpiar" Width="100" Padding="10" Margin="0,0,10,0" Background="#2196F3" Foreground="White"/>
                <Button Content="Cancelar" Width="100" Padding="10" Background="#f44336" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
