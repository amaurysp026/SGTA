<Page x:Class="SFCH.View.PCxC"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SFCH.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PCxC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Filtros -->
            <RowDefinition Height="*"/>
            <!-- Master -->
            <RowDefinition Height="Auto"/>
            <!-- Título detail -->
            <RowDefinition Height="*"/>
            <!-- Detail -->
            <RowDefinition Height="Auto"/>
            <!-- Panel abono -->
        </Grid.RowDefinitions>

        <!-- MASTER -->
        <DataGrid x:Name="data" Grid.Row="1"
              ItemsSource="{Binding Cuentas}"
              SelectedItem="{Binding CuentaSeleccionada}"
              AutoGenerateColumns="False"
              IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="CXC"      Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Cliente"  Binding="{Binding Cliente}"/>
                <DataGridTextColumn Header="Factura"  Binding="{Binding Descripcion}"/>
                <DataGridTextColumn Header="Pendiente"    Binding="{Binding MontoPendiente, 
                                                  StringFormat='{}{0:N2}'}"/>
                <DataGridTextColumn Header="Vence"    Binding="{Binding FechaVencimiento, 
                                                  StringFormat='{}{0:dd/MM/yyyy}'}"/>
                <DataGridTextColumn Header="Estado"   Binding="{Binding Pagado}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Título detalle dinámico -->
        <TextBlock Grid.Row="2" FontWeight="Bold" Margin="5"
               Text="{Binding CuentaSeleccionada.ClienteNombre, 
                     StringFormat='Movimientos de: {0}'}"/>

        <!-- DETAIL -->
        <DataGrid Grid.Row="3"
              ItemsSource="{Binding Movimientos}"
              AutoGenerateColumns="False"
              IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha"  Binding="{Binding FechaMovimiento, 
                                                StringFormat='{}{0:dd/MM/yyyy}'}"/>
                <DataGridTextColumn Header="Tipo"   Binding="{Binding TipoMovimiento}"/>
                <DataGridTextColumn Header="Monto"  Binding="{Binding Monto, 
                                                StringFormat='{}{0:N2}'}"/>
                <DataGridTextColumn Header="Forma"  Binding="{Binding FormaPago}"/>
                <DataGridTextColumn Header="Ref."   Binding="{Binding Referencia}"/>
            </DataGrid.Columns>
        </DataGrid>

       
    </Grid>
</Page>
