<Window x:Class="SFCH.VReportes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SFCH"
        mc:Ignorable="d"
        Title="Reporte de transacciones por Fecha" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <DatePicker Margin="10" Width="200" Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:HintAssist.Hint="Desde" Name="Desde"></DatePicker>
            <DatePicker Margin="10" Width="200" Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:HintAssist.Hint="Hasta" Name="Hasta"></DatePicker>
            <Button Margin="10" Height="50" Click="Button_Click">Procesar</Button>
            <Button Margin="10" Height="50" Click="Button_Click_2">Imprimir</Button>
        </StackPanel>
        <DataGrid Grid.Row="1"  x:Name="data" IsReadOnly="True" AutoGenerateColumns="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="No." Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha,StringFormat='dd/MM/yyyy'}" Width="auto"/>
                <DataGridTextColumn Header="Socio" Binding="{Binding Cuenta.Titular}" Width="auto"/>
                <DataGridTextColumn Header="Monto" Binding="{Binding Monto, StringFormat=RD$ {0:N2}}" Width="auto"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="auto"/>
                <DataGridTextColumn Header="Cuenta" Binding="{Binding Cuenta}" Width="auto"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Row="2" Name="txttotal" HorizontalAlignment="Right" Margin="10" FontSize="16" FontWeight="Bold">Total: RD$ 0.00</TextBlock>
    </Grid>
</Window>
